generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pg_trgm]
}

// ─────────────────────────────────────────────────────────────
// Enums (원본 도메인 enum 이식)
// ─────────────────────────────────────────────────────────────
enum Role {
  ROLE_USER
  ROLE_ADMIN
}

enum Status {
  JOIN
  WITHDRAWAL
}

enum OAuth2Provider {
  GOOGLE
  KAKAO
  NAVER
  LOCAL
}

enum DroppingType {
  MUSIC
  VOTE
  PLAYLIST
}

// ─────────────────────────────────────────────────────────────
// User (원본: PostgreSQL/JPA User)
// ─────────────────────────────────────────────────────────────
model User {
  id             Int            @id @default(autoincrement()) @map("user_id")
  username       String         @db.VarChar(15)
  password       String? // OAuth2 사용자는 비밀번호 없음
  profileImage   String         @default("https://mblogthumb-phinf.pstatic.net/MjAyMDExMDFfODMg/MDAxNjA0MjI4ODc1MDgz.gQ3xcHrLXaZyxcFAoEcdB7tJWuRs7fKgOxQwPvsTsrUg.0OBtKHq2r3smX5guFQtnT7EDwjzksz5Js0wCV4zjfpcg.JPEG.gambasg/%EC%9C%A0%ED%8A%9C%EB%B8%8C_%EA%B8%B0%EB%B3%B8%ED%94%84%EB%A1%9C%ED%95%84_%EB%B3%B4%EB%9D%BC.jpg?type=w400") @map("profile_image") @db.Text
  email          String         @unique
  role           Role           @default(ROLE_USER)
  birthDate      DateTime?      @map("birth_date") @db.Date
  gender         Boolean? // true: 남성, false: 여성
  status         Status         @default(JOIN)
  withdrawalDate DateTime?      @map("withdrawal_date")
  provider       OAuth2Provider @default(LOCAL)
  providerId     String?        @map("provider_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  comments  Comment[]
  likes     Like[]
  droppings Dropping[]

  @@index([provider, providerId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Comment (원본: PostgreSQL/JPA Comment)
// ─────────────────────────────────────────────────────────────
model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  userId     Int      @map("user_id")
  droppingId String   @map("dropping_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropping Dropping @relation(fields: [droppingId], references: [id], onDelete: Cascade)

  @@index([droppingId])
  @@map("comments")
}

// ─────────────────────────────────────────────────────────────
// Like (원본: PostgreSQL/JPA Like) — (user, dropping) 토글
// ─────────────────────────────────────────────────────────────
model Like {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  droppingId String   @map("dropping_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropping Dropping @relation(fields: [droppingId], references: [id], onDelete: Cascade)

  @@unique([userId, droppingId])
  @@index([droppingId])
  @@map("likes")
}

// ─────────────────────────────────────────────────────────────
// Song (원본: Elasticsearch nori → Postgres + pg_trgm)
//   title/artist 트라이그램 GIN 인덱스는 마이그레이션 SQL에서 생성
// ─────────────────────────────────────────────────────────────
model Song {
  id             String @id @default(uuid())
  title          String
  artist         String
  duration       Int // 재생 시간(초)
  albumImagePath String @map("album_image_path")

  @@map("songs")
}

// ─────────────────────────────────────────────────────────────
// Dropping (원본: MongoDB geo 2dsphere → Postgres + PostGIS)
//   하이브리드: 공통 컬럼은 관계형, payload 세부는 JSONB
//   payload 예)
//     MUSIC    : { "songId": "..." }
//     PLAYLIST : { "playlistName": "...", "songIds": ["...", ...] }
//     VOTE     : { "topic": "...", "optionVotes": { "<songId>": [userId, ...] } }
//   location(geography Point,4326)은 lat/lng로부터 트리거가 자동 채움(마이그레이션 SQL)
// ─────────────────────────────────────────────────────────────
model Dropping {
  id           String                                 @id @default(uuid())
  droppingType DroppingType                           @map("dropping_type")
  payload      Json                                   @db.JsonB
  userId       Int                                    @map("user_id")
  content      String?
  latitude     Float
  longitude    Float
  address      String?
  expiryDate   DateTime                               @map("expiry_date")
  createdAt    DateTime                               @default(now()) @map("created_at")
  isDeleted    Boolean                                @default(false) @map("is_deleted")
  location     Unsupported("geography(Point, 4326)")?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([userId])
  @@index([isDeleted, expiryDate])
  @@map("droppings")
}

// ─────────────────────────────────────────────────────────────
// Playlist (원본: MongoDB Playlist → Postgres)
//   songIds는 Postgres text[] 배열(하이브리드: 단순 리스트는 배열로)
// ─────────────────────────────────────────────────────────────
model Playlist {
  id      String   @id @default(uuid())
  name    String
  userId  Int      @map("user_id")
  songIds String[] @map("song_ids")

  @@index([userId])
  @@map("playlists")
}
