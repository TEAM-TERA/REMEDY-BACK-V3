# ── Database (PostgreSQL + PostGIS) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remedy?schema=public
# docker-compose 변수 (선택)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=remedy

# ── Auth ──
JWT_SECRET=replace-me-with-a-strong-secret-string
JWT_EXPIRES_IN=1d
PORT=3000

# ── AWS S3 (이미지 업로드, 선택) ──
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── OAuth2 (선택) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
