# ── Database (PostgreSQL + PostGIS) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remedy?schema=public
# docker-compose 변수 (선택)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=remedy

# ── Auth ──
JWT_SECRET=replace-me-with-a-strong-secret-string
JWT_EXPIRES_IN=1d
PORT=3000

# ── 실행 환경 / 로깅 ──
# production 이면 JSON 로그(로그 수집기 친화), 그 외에는 pretty 로그.
NODE_ENV=development
# 로그 레벨(선택): trace|debug|info|warn|error|fatal|silent. 미설정 시 환경별 기본값.
# (빈 값으로 두지 말 것 — 설정하려면 주석 해제 후 유효 레벨 지정)
# LOG_LEVEL=info

# ── AWS S3 (이미지 업로드, 선택) ──
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── OAuth2 (선택) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 외부 음원 소스 ──
# Spotify(검색·곡 식별, Client Credentials). 미설정 시 검색/곡 fetch 가 502.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# YouTube Data API(곡당 1회 매칭). 미설정 시 YouTube 가용성은 미확인/미지원 처리.
YOUTUBE_API_KEY=

# 검색 레이트 리밋(IP 기준, 선택). 기본 30회 / 60초.
SEARCH_RATE_LIMIT=30
SEARCH_RATE_TTL_MS=60000
